
DECLARE
    CURSOR emp_cursor IS
        SELECT emp_id, salary FROM employee;

    v_id employee.emp_id%TYPE;
    v_salary employee.salary%TYPE;

BEGIN
    OPEN emp_cursor;

    LOOP
        FETCH emp_cursor INTO v_id, v_salary;
        EXIT WHEN emp_cursor%NOTFOUND;

        UPDATE employee
        SET salary = v_salary + (v_salary * 0.05)
        WHERE emp_id = v_id;

    END LOOP;

    CLOSE emp_cursor;

    DBMS_OUTPUT.PUT_LINE('Salary updated by 5%');
END;
/
