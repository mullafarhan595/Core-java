
DECLARE
    num NUMBER := 5;
    result NUMBER;

    -- Function to calculate factorial
    FUNCTION factorial(n NUMBER) RETURN NUMBER IS
        fact NUMBER := 1;
    BEGIN
        FOR i IN 1..n LOOP
            fact := fact * i;
        END LOOP;
        RETURN fact;
    END;

BEGIN
    result := factorial(num);
    DBMS_OUTPUT.PUT_LINE('Factorial of ' || num || ' is ' || result);
END;
/
