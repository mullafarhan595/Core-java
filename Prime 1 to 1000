
DECLARE
    i NUMBER;
    j NUMBER;
    is_prime BOOLEAN;
BEGIN
    FOR i IN 2..1000 LOOP
        is_prime := TRUE;

        FOR j IN 2..i-1 LOOP
            IF MOD(i, j) = 0 THEN
                is_prime := FALSE;
                EXIT;
            END IF;
        END LOOP;

        IF is_prime THEN
            DBMS_OUTPUT.PUT_LINE(i);
        END IF;
    END LOOP;
END;
/
